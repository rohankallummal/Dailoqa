# Copy to .env.local and fill in. .env.local is gitignored.
APP_URL=http://localhost:3000

# Postgres connection string
# If the password has special characters (@ : / # etc.) URL-encode them (e.g. @ -> %40).
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# 32-byte base64 secret for signing the session JWT (HS256)
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# 32-byte base64 key for AES-256-GCM encryption of Google refresh tokens
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Google OAuth credentials (from Google Cloud Console → Credentials → OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
